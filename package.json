{
  "name": "hvx",
  "version": "0.1.0",
  "private": true,
  "description": "HVX: HEMS Past-Exam Video Explainer Learning System MVP",
  "scripts": {
    "start:all": "concurrently \"pnpm dev\" \"pnpm docs:dev\" \"pnpm db:studio\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs --watch --port 4000",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "db:push": "drizzle-kit push --config=./config/drizzle.config.ts",
    "db:migrate": "drizzle-kit generate --config=./config/drizzle.config.ts",
    "db:update": "drizzle-kit migrate --config=./config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=./config/drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config=./config/drizzle.config.ts",
    "db:seed": "tsx drizzle/seed.ts",
    "test:unit": "vitest --config=./config/vitest.config.mts",
    "test:e2e": "playwright test --config=./config/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=./config/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=./config/playwright.config.ts --debug"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.89.0",
    "@tailwindcss/postcss": "4.1.18",
    "@tanstack/react-query": "5.90.16",
    "@tanstack/react-query-devtools": "5.91.2",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "axios": "1.13.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.1",
    "lucide-react": "0.562.0",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "nextjs-toploader": "3.9.17",
    "postgres": "3.4.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.0",
    "recharts": "3.8.0",
    "resend": "6.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.18",
    "zod": "4.3.5",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@eslint/json": "0.14.0",
    "@eslint/markdown": "7.5.1",
